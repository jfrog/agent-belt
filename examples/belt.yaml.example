# belt LLM judge configuration
# Copy to belt.yaml and fill in your values.
# Auto-discovered by walking up from the working directory.
#
# Credentials come from BELT_* environment variables:
#   OpenAI:    BELT_OPENAI_API_KEY
#   Azure:     BELT_AZURE_OPENAI_ENDPOINT + BELT_AZURE_OPENAI_API_KEY (or SP creds)
#   Anthropic: BELT_ANTHROPIC_API_KEY
#   Ollama:    none (auto-detected at http://localhost:11434)

llm:
  # Provider prefix is required: openai/, azure/, anthropic/, ollama/
  model: openai/gpt-5.4-mini
  # temperature: 0.0
  # seed: 2008
  # max_tokens: 4096

  # Azure deployments often have arbitrary names. You can either prefix
  # them (`azure/my-deployment`) or set `provider:` and leave `model:`
  # unprefixed:
  #   provider: azure
  #   model: my-deployment

  # Required for Azure custom deployments (no built-in pricing). Without
  # these, cost shows as "unknown".
  # cost_per_prompt_token: 0.000002      # USD per token ($2/1M)
  # cost_per_completion_token: 0.000008  # USD per token ($8/1M)
